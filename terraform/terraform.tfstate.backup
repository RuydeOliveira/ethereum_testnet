      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:ec2:us-east-1:288234451032:volume/vol-0379b706257f3707e",
            "availability_zone": "us-east-1a",
            "create_time": "2026-03-13T22:20:57Z",
